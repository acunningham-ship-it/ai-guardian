# AI Guardian Configuration
GUARDIAN_PORT=9191
GUARDIAN_HOST=0.0.0.0
GUARDIAN_SECRET=change-me-to-a-random-secret

# Supported API keys (users provide their own)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=sqlite+aiosqlite:///./guardian.db

# Default budget limits (USD)
DEFAULT_MONTHLY_BUDGET=100
DEFAULT_DAILY_BUDGET=10
DEFAULT_HARD_CAP=true

# Model routing preferences
PREFER_CHEAP_MODELS=true
FALLBACK_ORDER=anthropic/claude-sonnet-4,openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-opus-4

# Quality guardrails
ENABLE_CODE_VALIDATION=true
ENABLE_SECURITY_SCAN=true
ENABLE_PERFORMANCE_CHECK=true
MAX_TOKEN_PER_REQUEST=4096

# Agent monitoring
MAX_AGENT_ITERATIONS=20
AGENT_TIMEOUT_SECONDS=300
