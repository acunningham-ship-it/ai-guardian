[Unit]
Description=AI Guardian - Smart AI Proxy
After=network.target

[Service]
Type=simple
User=armani
WorkingDirectory=/home/armani/ai-guardian
EnvironmentFile=/home/armani/ai-guardian/.env
ExecStart=/usr/bin/python3 /home/armani/ai-guardian/main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
